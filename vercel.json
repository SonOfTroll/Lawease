{
    "builds": [
        {
            "src": "chatboy/app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/chatboy/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/chatboy/app.py"
        }
    ]
}
